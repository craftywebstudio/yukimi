---
import { restaurant } from "../data/restaurant";
---

<section class="hero" id="top">
  <div class="hero-media">
    <img
      src="/images/interieur-1.jpg"
      alt="Entrée du restaurant Yukimi, comptoir et lanternes japonaises"
      loading="eager"
    />
    <div class="hero-scrim"></div>
  </div>

  <div class="glow-orb hero-orb-pink" aria-hidden="true"></div>
  <div class="glow-orb hero-orb-cyan" aria-hidden="true"></div>

  <div class="container hero-content">
    <p class="eyebrow hero-eyebrow">Restaurant japonais à volonté · {restaurant.city}</p>

    <div class="hero-lockup">
      <img
        src="/images/logo-header.jpg"
        alt="Yukimi ゆきみ"
        class="hero-logo"
      />
      <div class="hero-text-block">
        <h1 class="visually-hidden">Yukimi — restaurant japonais à volonté à Montpellier</h1>
        <p class="hero-text">
          Sushi, yakitori et ramen à volonté dans une salle chaleureuse au cœur
          de Montpellier. Une formule unique, un service attentionné.
        </p>
        <div class="hero-actions">
          <a class="btn btn-gold" href={`tel:${restaurant.phoneHref}`}>
            <svg class="icon-phone" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.5 21 3 13.5 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1L6.6 10.8z"
                fill="currentColor"
              ></path>
            </svg>
            Réserver · {restaurant.phone}
          </a>
          <a class="btn btn-outline" href="#formules">Voir la formule</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: clip;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: hero-zoom 16s ease-out forwards;
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1.08);
    }
    to {
      transform: scale(1);
    }
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 7, 20, 0.65) 0%,
      rgba(10, 7, 20, 0.4) 35%,
      rgba(10, 7, 20, 0.95) 92%
    );
  }

  .hero-orb-pink {
    top: -120px;
    right: -80px;
    width: 420px;
    height: 420px;
    background: var(--neon-pink);
    z-index: 1;
  }

  .hero-orb-cyan {
    bottom: 10%;
    left: -140px;
    width: 380px;
    height: 380px;
    background: var(--neon-cyan);
    z-index: 1;
    animation-delay: 2.5s;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 88px;
    padding-top: 200px;
    max-width: 960px;
  }

  .hero-eyebrow {
    opacity: 0;
    animation: hero-fade-up 0.7s ease 0.1s forwards;
  }

  .hero-lockup {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 52px;
    opacity: 0;
    animation: hero-fade-up 0.8s ease 0.35s forwards;
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-logo {
    width: 400px;
    height: auto;
    flex-shrink: 0;
    /* Le fichier source a un fond noir : "screen" le rend transparent
       et ne laisse apparaître que le trait rouge et le lettrage blanc. */
    mix-blend-mode: screen;
    filter: drop-shadow(0 0 22px rgba(255, 63, 160, 0.25));
    animation: logo-glow 5s ease-in-out infinite;
  }

  @keyframes logo-glow {
    0%,
    100% {
      filter: drop-shadow(0 0 18px rgba(255, 63, 160, 0.2));
    }
    50% {
      filter: drop-shadow(0 0 32px rgba(55, 233, 255, 0.3));
    }
  }

  .hero-text-block {
    max-width: 460px;
  }

  .hero-text {
    color: var(--cream);
    opacity: 0.9;
    font-size: 1.2rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .icon-phone {
    width: 15px;
    height: 15px;
  }

  .hero-actions .btn-gold {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media img,
    .hero-eyebrow,
    .hero-lockup,
    .hero-logo,
    .glow-orb {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .hero-content {
      padding-top: 140px;
      padding-bottom: 64px;
    }

    .hero-lockup {
      flex-direction: column;
      align-items: flex-start;
      gap: 28px;
    }

    .hero-logo {
      width: 240px;
    }
  }
</style>
