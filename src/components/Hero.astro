---
import { restaurant } from "../data/restaurant";
---

<section class="hero" id="top">
  <div class="hero-media">
    <img
      src="/images/gallery-neon-ceiling.jpg"
      alt="Enseignes lumineuses et ombrelles japonaises suspendues dans la salle du restaurant Yukimi"
      loading="eager"
    />
    <div class="hero-scrim"></div>
  </div>

  <div class="glow-orb hero-orb-pink" aria-hidden="true"></div>
  <div class="glow-orb hero-orb-cyan" aria-hidden="true"></div>

  <div class="container hero-content">
    <p class="eyebrow hero-eyebrow">ようこそ · WELCOME</p>

    <div class="hero-lockup">
      <img
        src="/images/logo-header.jpg"
        alt="Yukimi ゆきみ"
        class="hero-logo"
      />
      <div class="hero-text-block">
        <h1 class="hero-title">
          YUKIMI
          <span class="hero-title-sub">Restaurant japonais</span>
        </h1>
        <p class="hero-text">
          Sushi et yakitori à volonté dans une salle chaleureuse au cœur
          de Montpellier. Une formule unique, un service attentionné.
        </p>
        <div class="hero-actions">
          <a class="btn btn-neon" href="#formules">Voir la formule</a>
          <a class="btn btn-outline" href={restaurant.mapsDirectionsUrl} target="_blank" rel="noopener">
            Itinéraire
          </a>
        </div>
        <p class="hero-meta">
          <span>{restaurant.address.full}</span>
          <span class="hero-meta-dot" aria-hidden="true">✦</span>
          <span>{restaurant.phone}</span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: clip;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: hero-zoom 16s ease-out forwards;
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1.08);
    }
    to {
      transform: scale(1);
    }
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 7, 20, 0.65) 0%,
      rgba(10, 7, 20, 0.4) 35%,
      rgba(10, 7, 20, 0.95) 92%
    );
  }

  .hero-orb-pink {
    top: -120px;
    right: -80px;
    width: 420px;
    height: 420px;
    background: var(--neon-pink);
    z-index: 1;
  }

  .hero-orb-cyan {
    bottom: 10%;
    left: -140px;
    width: 380px;
    height: 380px;
    background: var(--neon-cyan);
    z-index: 1;
    animation-delay: 2.5s;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 88px;
    padding-top: 200px;
    max-width: 960px;
  }

  .hero-eyebrow {
    opacity: 0;
    animation: hero-fade-up 0.7s ease 0.1s forwards;
  }

  .hero-lockup {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 52px;
    opacity: 0;
    animation: hero-fade-up 0.8s ease 0.35s forwards;
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-logo {
    width: 400px;
    height: auto;
    flex-shrink: 0;
    /* Le fichier source a un fond noir : "screen" le rend transparent
       et ne laisse apparaître que le trait rouge et le lettrage blanc. */
    mix-blend-mode: screen;
    filter: drop-shadow(0 0 22px rgba(255, 63, 160, 0.25));
    animation: logo-glow 5s ease-in-out infinite;
  }

  @keyframes logo-glow {
    0%,
    100% {
      filter: drop-shadow(0 0 18px rgba(255, 63, 160, 0.2));
    }
    50% {
      filter: drop-shadow(0 0 32px rgba(55, 233, 255, 0.3));
    }
  }

  .hero-text-block {
    max-width: 460px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.92;
    font-size: clamp(2.6rem, 5.6vw, 4.4rem);
    letter-spacing: 0.02em;
    color: var(--cream);
    text-shadow: 0 0 28px rgba(255, 63, 160, 0.35);
    margin-bottom: 18px;
  }

  .hero-title-sub {
    display: block;
    font-size: clamp(0.95rem, 1.6vw, 1.2rem);
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.28em;
    color: var(--neon-cyan);
    text-shadow: 0 0 14px rgba(55, 233, 255, 0.4);
    margin-top: 10px;
  }

  .hero-text {
    color: var(--cream);
    opacity: 0.9;
    font-size: 1.2rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .hero-meta-dot {
    color: var(--neon-pink);
    font-size: 0.7rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media img,
    .hero-eyebrow,
    .hero-lockup,
    .hero-logo,
    .glow-orb {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .hero-content {
      padding-top: 140px;
      padding-bottom: 64px;
    }

    .hero-lockup {
      flex-direction: column;
      align-items: flex-start;
      gap: 28px;
    }

    .hero-logo {
      width: 240px;
    }
  }
</style>
