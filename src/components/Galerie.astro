---
const photos = [
  { src: "/images/interieur-1.jpg", alt: "Entrée du restaurant Yukimi, décor japonais et lanternes" },
  { src: "/images/plateau.jpg", alt: "Plateau de sushi, sashimi, yakitori et gyoza" },
  { src: "/images/interieur-2.jpg", alt: "Intérieur du restaurant Yukimi" },
];
---

<section class="section" id="galerie">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Ambiance</p>
      <h2>Un izakaya au cœur de Montpellier</h2>
    </div>

    <div class="gallery-grid" data-reveal-stagger>
      {photos.map((photo) => (
        <figure class="gallery-item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          <span class="gallery-glow" aria-hidden="true"></span>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    grid-template-rows: repeat(2, 220px);
    gap: 16px;
  }

  .gallery-item:first-child {
    grid-row: span 2;
  }

  .gallery-item {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--line);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .gallery-item:hover {
    border-color: rgba(255, 63, 160, 0.5);
    box-shadow: 0 0 30px rgba(255, 63, 160, 0.18);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
    filter: saturate(1.15);
  }

  .gallery-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 63, 160, 0.18),
      transparent 40%,
      rgba(55, 233, 255, 0.14)
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .gallery-item:hover .gallery-glow {
    opacity: 1;
  }

  @media (max-width: 720px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }

    .gallery-item {
      height: 260px;
    }

    .gallery-item:first-child {
      grid-row: auto;
    }
  }
</style>
