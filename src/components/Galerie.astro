---
const photos = [
  { src: "/images/interieur-1.jpg", alt: "Entrée du restaurant Yukimi, décor japonais et lanternes" },
  { src: "/images/plateau.jpg", alt: "Plateau de sushi, sashimi, yakitori et gyoza" },
  { src: "/images/interieur-2.jpg", alt: "Intérieur du restaurant Yukimi" },
];
---

<section class="section" id="galerie">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Ambiance</p>
      <h2>Un izakaya au cœur de Montpellier</h2>
    </div>

    <div class="gallery-grid">
      {photos.map((photo) => (
        <figure class="gallery-item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    grid-template-rows: repeat(2, 220px);
    gap: 16px;
  }

  .gallery-item:first-child {
    grid-row: span 2;
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  @media (max-width: 720px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }

    .gallery-item {
      height: 260px;
    }

    .gallery-item:first-child {
      grid-row: auto;
    }
  }
</style>
