---
import { restaurant, openingHours } from "../data/restaurant";
---

<section class="section seigaiha" id="localisation">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">アクセス</p>
      <h2>Nous trouver</h2>
    </div>

    <div class="loc-grid">
      <div class="loc-blocks" data-reveal-stagger>
        <div class="loc-block">
          <h3 class="loc-block-title">Adresse</h3>
          <p class="loc-block-text">{restaurant.address.full}</p>
          <a class="loc-block-link" href={restaurant.mapsDirectionsUrl} target="_blank" rel="noopener">
            Obtenir l'itinéraire
          </a>
        </div>

        <div class="loc-block">
          <h3 class="loc-block-title">Téléphone</h3>
          <a class="loc-block-link loc-block-phone" href={`tel:${restaurant.phoneHref}`}>
            {restaurant.phone}
          </a>
        </div>

        <div class="loc-block">
          <h3 class="loc-block-title">Horaires</h3>
          <table class="hours-table">
            <tbody>
              {openingHours.map((day) => (
                <tr>
                  <th scope="row">{day.day}</th>
                  <td>
                    {day.slots.map((slot) => (
                      <span class="hours-slot">{slot}</span>
                    ))}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="loc-block">
          <h3 class="loc-block-title">Réseaux sociaux</h3>
          <a class="loc-block-link" href={restaurant.social.facebook} target="_blank" rel="noopener">
            facebook.com/yukimiFR
          </a>
        </div>
      </div>

      <div class="loc-map" data-reveal>
        <iframe
          src={restaurant.mapsEmbedUrl}
          title="Localisation du restaurant Yukimi sur Google Maps"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .loc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .loc-grid {
      grid-template-columns: 1fr;
    }
  }

  .loc-blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 40px;
  }

  @media (max-width: 560px) {
    .loc-blocks {
      grid-template-columns: 1fr;
    }
  }

  .loc-block-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--neon-cyan);
    text-shadow: 0 0 10px rgba(55, 233, 255, 0.35);
    margin-bottom: 10px;
  }

  .loc-block-text {
    color: var(--muted);
    font-size: 0.98rem;
    margin-bottom: 8px;
  }

  .loc-block-link {
    display: inline-block;
    color: var(--cream);
    font-size: 0.98rem;
    font-weight: 600;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .loc-block-link:hover {
    color: var(--neon-pink);
    border-color: var(--neon-pink);
  }

  .loc-block-phone {
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .hours-table {
    width: 100%;
    border-collapse: collapse;
  }

  .hours-table tr {
    border-bottom: 1px solid var(--line);
    transition: background 0.2s ease;
  }

  .hours-table tr:last-child {
    border-bottom: none;
  }

  .hours-table tr:hover {
    background: linear-gradient(90deg, rgba(55, 233, 255, 0.05), transparent 70%);
  }

  .hours-table th,
  .hours-table td {
    padding: 8px 0;
    text-align: left;
    font-weight: 400;
    font-size: 0.88rem;
  }

  .hours-table th {
    color: var(--cream);
    width: 46%;
  }

  .hours-table td {
    color: var(--muted);
  }

  .hours-slot {
    display: block;
  }

  .loc-map {
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--line);
    min-height: 380px;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .loc-map:hover {
    border-color: rgba(55, 233, 255, 0.4);
    box-shadow: 0 0 30px rgba(55, 233, 255, 0.15);
  }

  .loc-map iframe {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
    filter: grayscale(0.3) invert(0.92) contrast(0.9);
  }
</style>
