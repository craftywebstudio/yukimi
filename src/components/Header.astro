---
import { restaurant } from "../data/restaurant";

const navLinks = [
  { href: "/#formules", label: "Formules" },
  { href: "/#carte", label: "La carte" },
  { href: "/#galerie", label: "Galerie" },
  { href: "/#localisation", label: "Où nous trouver" },
];
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/#top" class="brand">
      <img src="/favicon-192.png" alt="" class="brand-mark" />
      <span class="brand-wordmark">YUKIMI</span>
    </a>

    <nav class="nav" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="btn btn-gold btn-reserve" href={`tel:${restaurant.phoneHref}`}>
        <svg class="icon-phone" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.5 21 3 13.5 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1L6.6 10.8z"
            fill="currentColor"
          ></path>
        </svg>
        Réserver
      </a>
      <a class="itineraire-link" href={restaurant.mapsDirectionsUrl} target="_blank" rel="noopener">
        <svg class="icon-pin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 22s7-7.58 7-12.5A7 7 0 1 0 5 9.5C5 14.42 12 22 12 22z"
            stroke="currentColor"
            stroke-width="1.6"
          ></path>
          <circle cx="12" cy="9.5" r="2.4" stroke="currentColor" stroke-width="1.6"></circle>
        </svg>
        Itinéraire
      </a>
    </div>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="mobile-nav">
      <span></span>
      <span></span>
      <span></span>
      <span class="visually-hidden">Ouvrir le menu</span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Navigation mobile">
    {navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a class="btn btn-gold" href={`tel:${restaurant.phoneHref}`}>
      Réserver · {restaurant.phone}
    </a>
    <a class="mobile-itineraire" href={restaurant.mapsDirectionsUrl} target="_blank" rel="noopener">
      Itinéraire
    </a>
  </nav>
</header>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");

  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 40);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener("click", () => {
    const isOpen = mobileNav?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });

  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileNav.classList.remove("is-open");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 7, 20, 0.55);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }

  .site-header.is-scrolled {
    background: rgba(10, 7, 20, 0.9);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .brand-mark {
    height: 40px;
    width: 40px;
    border-radius: 50%;
    box-shadow: 0 0 0 1px rgba(255, 63, 160, 0.25), 0 0 18px rgba(255, 63, 160, 0.25);
    transition: box-shadow 0.3s ease;
  }

  .brand:hover .brand-mark {
    box-shadow: 0 0 0 1px rgba(55, 233, 255, 0.4), 0 0 22px rgba(55, 233, 255, 0.35);
  }

  .brand-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.55rem;
    letter-spacing: 0.04em;
    color: var(--cream);
    text-shadow: 0 0 18px rgba(255, 63, 160, 0.35);
    line-height: 1;
  }

  .nav {
    display: flex;
    gap: 30px;
  }

  .nav a {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--cream);
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 4px;
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2px;
    background: var(--neon-cyan);
    box-shadow: 0 0 8px var(--neon-cyan);
    transition: width 0.3s ease;
  }

  .nav a:hover {
    color: var(--neon-cyan);
  }

  .nav a:hover::after {
    width: 100%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .btn-reserve {
    padding: 11px 22px;
  }

  .icon-phone {
    width: 15px;
    height: 15px;
  }

  .btn-reserve {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .itineraire-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .itineraire-link:hover {
    color: var(--neon-cyan);
  }

  .icon-pin {
    width: 15px;
    height: 15px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 2px;
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--cream);
    margin: 0 auto;
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 860px) {
    .nav,
    .header-actions {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .site-header {
      background: rgba(10, 7, 20, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }

    .brand-mark {
      height: 34px;
      width: 34px;
    }

    .brand-wordmark {
      font-size: 1.25rem;
    }

    .mobile-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      max-height: 0;
      overflow: hidden;
      padding: 0 24px;
      background: var(--ink-2);
      transition: max-height 0.3s ease, padding 0.3s ease;
    }

    .mobile-nav.is-open {
      max-height: 420px;
      padding: 16px 24px 24px;
    }

    .mobile-nav a:not(.btn) {
      padding: 10px 0;
      border-bottom: 1px solid var(--line);
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      font-weight: 600;
    }

    .mobile-itineraire {
      border-bottom: none !important;
      color: var(--muted);
      text-transform: none !important;
      font-weight: 400 !important;
      letter-spacing: normal !important;
    }

    .mobile-nav .btn {
      margin-top: 12px;
      width: fit-content;
    }
  }
</style>
